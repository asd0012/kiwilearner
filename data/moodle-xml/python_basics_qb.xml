    <questiontext format="html"><text><![CDATA[d = {'a': 1, 'b': 2}, how do you remove key 'a'?]]></text></questiontext>
    <defaultgrade>1</defaultgrade>
    <single>true</single>
    <shuffleanswers>true</shuffleanswers>
    <answernumbering>abc</answernumbering>
    <answer fraction="100"><text>del d['a']</text></answer>
    <answer fraction="0"><text>d.pop('a')</text></answer>
    <answer fraction="0"><text>d.remove('a')</text></answer>
    <answer fraction="0"><text>None</text></answer>
    <tags><tag><text>dictionaries</text></tag></tags>
</question>

